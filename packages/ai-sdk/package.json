{
  "name": "@dockline/ai-sdk",
  "version": "0.1.0-alpha.1",
  "description": "Vercel AI SDK bridge for Dockline chat models and providers.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EtienneLescot/dockline.git",
    "directory": "packages/ai-sdk"
  },
  "homepage": "https://github.com/EtienneLescot/dockline#readme",
  "bugs": {
    "url": "https://github.com/EtienneLescot/dockline/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "ai-sdk",
    "llm",
    "model-provider",
    "typescript",
    "vercel"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@dockline/core": "0.1.0-alpha.1"
  },
  "peerDependencies": {
    "@ai-sdk/provider": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/provider": {
      "optional": true
    }
  }
}
