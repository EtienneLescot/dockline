{
  "name": "@dockline/mistral",
  "version": "0.1.0-alpha.1",
  "description": "Mistral LangChain-backed chat provider for Dockline.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EtienneLescot/dockline.git",
    "directory": "packages/mistral"
  },
  "homepage": "https://github.com/EtienneLescot/dockline#readme",
  "bugs": {
    "url": "https://github.com/EtienneLescot/dockline/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "langchain",
    "llm",
    "mistral",
    "model-provider",
    "typescript"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@dockline/core": "0.1.0-alpha.1",
    "@dockline/langchain-provider": "0.1.0-alpha.1"
  },
  "peerDependencies": {
    "@langchain/mistralai": ">=0.2.0"
  },
  "peerDependenciesMeta": {
    "@langchain/mistralai": {
      "optional": true
    }
  }
}
