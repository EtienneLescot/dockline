{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "paths": {
      "@dockline/core": ["packages/core/src/index.ts"],
      "@dockline/ai-sdk": ["packages/ai-sdk/src/index.ts"],
      "@dockline/all": ["packages/all/src/index.ts"],
      "@dockline/anthropic": ["packages/anthropic/src/index.ts"],
      "@dockline/catalog": ["packages/catalog/src/index.ts"],
      "@dockline/google": ["packages/google/src/index.ts"],
      "@dockline/langchain": ["packages/langchain/src/index.ts"],
      "@dockline/langchain-provider": ["packages/langchain-provider/src/index.ts"],
      "@dockline/mistral": ["packages/mistral/src/index.ts"],
      "@dockline/openai": ["packages/openai/src/index.ts"],
      "@dockline/openai-compatible": ["packages/openai-compatible/src/index.ts"],
      "@dockline/openrouter": ["packages/openrouter/src/index.ts"],
      "@dockline/providers": ["packages/providers/src/index.ts"],
      "@dockline/resolver": ["packages/resolver/src/index.ts"]
    }
  }
}
