{
  "name": "dockline",
  "private": true,
  "version": "0.0.0",
  "description": "Capability-aware model connector layer for JS/TS agents.",
  "type": "module",
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/*",
    "typecheck": "tsc -b packages/* --pretty false",
    "test": "node --test",
    "clean": "find packages -name dist -type d -prune -exec rm -rf {} +"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
